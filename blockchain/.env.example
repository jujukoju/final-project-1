# blockchain/.env
# Copy this file and fill in the real values. NEVER commit real keys to git.

# Your MetaMask account private key (for Sepolia deployment)
# PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Sepolia JSON-RPC endpoint — get a free one from Alchemy or Infura
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Etherscan API key (optional — used for contract verification)
# ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Set to "true" to enable gas cost reporting during tests
# REPORT_GAS=true
