# oracle-api/.env
# Copy this file and fill in the real values. NEVER commit real keys to git.

# Deployed IdentityRegistry contract address (from blockchain/deployed.json after deploy)
# CONTRACT_ADDRESS=0x...

# Path to blockchain/deployed.json (contains ABI + address)
# ABI_PATH=../blockchain/deployed.json

# Oracle account private key (the same account used as 'oracle' during contract deployment)
# This is a Hardhat test account — replace with your real key for Sepolia
# PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# JSON-RPC endpoint
# RPC_URL=http://127.0.0.1:8545
